<script>
    let currentPage = 1;

    function loadZone(page=1){

    currentPage = page;
    alert(page)

    let search = $("#search").val();

        $.get(`http://localhost:7258/api/Zone?search=${search}&page=${page}`, function(res){

    let html="";

    res.data.forEach(c=>{

    html += `
    <tr>

        <td>${c.zoneId}</td>
        <td>${c.zoneName}</td>
        <td>${c.isInternational ? "International" : "Domestic"}</td>
        <td>${c.isActive}</td>

        <td>

            <button class="btn btn-sm btn-primary"
                    onclick="editZone(${c.zoneId},'${c.zoneName}',${c.isActive})">

                ✏️
            </button>

            <button class="btn btn-sm btn-danger"
                    onclick="deleteZone(${c.zoneId})">

                🗑
            </button>

        </td>

    </tr>`;

    });

    $("#tblZone").html(html);

    createPagination(res.total,page);

    });

    }
        function saveZone(){
            debugger;
            let zoneId = $("#zoneId").val();

        let zone = {

        zoneName: $("#zoneName").val(),
                isInternational: $("#isInternational").prop("checked"),
        isActive: $("#isActive").prop("checked")

        };

            if(zoneId==""){

        $.ajax({

            url:"http://localhost:7258/api/Zone",
        method:"POST",
        contentType:"application/json",
        data: JSON.stringify(zone),
        success:function(){

        loadZone(currentPage);

        }
             ,error: function () {

                                alert("Error saving state");

                            }
        });

        }
        else{

        $.ajax({

                url:`http://localhost:7258/api/Zone/${zoneId}`,
        method:"PUT",
        contentType:"application/json",
        data: JSON.stringify(zone),
        success:function(){

        loadZone(currentPage);

        }
             ,error: function () {

                            alert("Error saving state");

                        }

        });

        }

        }
        @*Edit function*@
                function editZone(zoneId,name,isActive){

            $("#zoneId").val(zoneId);
        $("#zoneName").val(name);
        $("#isActive").prop("checked",isActive);

        }

            @*Delete function*@
                function deleteZone(zoneId){

        if(confirm("Delete this record?")){

        $.ajax({

                url:`http://localhost:7258/api/Zone/${zoneId}`,
        method:"DELETE",
        success:function(){

        loadZone(currentPage);

        }

        });

        }

        }

            function createPagination(total,page){

        let pageSize=5;

        let pages = Math.ceil(total/pageSize);

        let html="";

        for(let i=1;i<=pages;i++){

        html += `<button onclick="loadZone(${i})">${i}</button>`;

        }

        $("#pagination").html(html);

        }

            let table;

        $(document).ready(function(){

        loadZone();

        });

        function loadZone(){

        apiService.get("http://localhost:7258/api/Zone")
        .then(data=>{

        if(table){
        table.destroy();
        }

        let html="";

        data.forEach(c=>{

        html+=`<tr>

        <td>${c.zoneId}</td>
        <td>${c.zoneName}</td>
    <td>${c.isInternational ? "International" : "Domestic"}</td>
        <td>${c.isActive}</td>

        <td>

        <button class="btn btn-sm btn-primary"
        onclick="editZone(${c.zoneId},'${c.zoneName}','${c.isInternational}',${c.isActive})">

        ✏️
        </button>

        <button class="btn btn-sm btn-danger"
        onclick="deleteZone(${c.zoneId})">

        🗑
        </button>

        </td>

        </tr>`;

        });

        $("#zoneTable tbody").html(html);

        table = $("#zoneTable").DataTable();

        });

        }


            function openAddModal(){

        $("#zoneId").val("");
        $("#zoneName").val("");
            $("#isInternational").prop("checked",true);
        $("#isActive").prop("checked",true);

        $("#zoneModal").modal("show");

        }


                function editZone(zoneId,name,type,isActive){

            $("#zoneId").val(zoneId);
        $("#zoneName").val(name);
                $("#isInternational").prop("checked",isInternational);
        $("#isActive").prop("checked",isActive);

        $("#zoneModal").modal("show");

        }

        //Save
            function saveZone(){

            let zoneId=$("#zoneId").val();

        let zone={
                            //zoneId:$("#zoneId").val(),
        zoneName:$("#zoneName").val(),
            isInternational:$("#isInternational").prop("checked"),
        isActive:$("#isActive").prop("checked")

        };

            if(zoneId==""){

        apiService.post("http://localhost:7258/api/Zone",zone)
        .then(()=>{

        $("#zoneModal").modal("hide");
        loadZone();

        });

        }
        else{

        apiService.put(`http://localhost:7258/api/Zone/${zoneId}`,zone)
        .then(()=>{

        $("#zoneModal").modal("hide");
        loadZone();

        });

        }

        }

        //Delete
            function deleteZone(zoneId){

    Swal.fire({

    title:"Are you sure?",
    text:"This record will be deleted!",
    icon:"warning",
    showCancelButton:true,
    confirmButtonText:"Yes delete"

    }).then((result)=>{

    if(result.isConfirmed){

        apiService.delete(`http://localhost:7258/api/Zone/${zoneId}`)
    .then(()=>{

    Swal.fire("Deleted!","Record deleted.","success");

    loadZone();

    });

    }

    });

    }

        const apiService = {

        get: function(url){
        return $.get(url);
        },

        post: function(url,data){
        return $.ajax({
        url:url,
        method:"POST",
        contentType:"application/json",
        data:JSON.stringify(data)
        });
        },

        put: function(url,data){
        return $.ajax({
        url:url,
        method:"PUT",
        contentType:"application/json",
        data:JSON.stringify(data)
        });
        },

        delete: function(url){
        return $.ajax({
        url:url,
        method:"DELETE"
        });
        }

        };
</script>