
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div id="loader" style="display:none; position:fixed; top:50%; left:50%;">
    <div class="spinner-border text-primary"></div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background: #f5f7fb;
    }

    .card {
        border-radius: 12px;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .btn {
        border-radius: 8px;
    }

    .modal-content {
        border-radius: 14px;
    }

    .table-hover tbody tr:hover {
        background: #f1f5ff;
    }
</style>
<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Airline Master</h3>
            <small class="text-muted">Manage airline slabs and configuration</small>
        </div>
        <button class="btn btn-primary shadow-sm" id="btnAdd">
            <i class="bi bi-plus-lg"></i> Add Airline
        </button>
    </div>

    <!-- TOOLBAR -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex gap-2">

            <input type="text" id="search" class="form-control w-25"
                   placeholder="🔍 Search airline...">

            <button class="btn btn-outline-primary" id="btnSearch">
                Search
            </button>

            <button class="btn btn-outline-secondary" onclick="loadData()">
                Reset
            </button>

        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="card border-0 shadow-sm">
        <div class="card-body table-responsive">

            <table class="table align-middle table-hover">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Airline Code</th>
                        <th>Airline Name</th>
                        <th>Slab 1</th>
                        <th>Slab 2</th>
                        <th>Slab 3</th>
                        <th>Slab 4</th>
                        <th>Slab 5</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody id="tblData"></tbody>
            </table>

        </div>
    </div>
</div>


<div class="modal fade" id="airlineModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header bg-primary text-white">
                <h5 id="modalTitle" class="fw-semibold">Add Airline</h5>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="">

                <!-- BASIC INFO -->
                <div class="row g-3 mb-3">

                    <div class="col-md-4">
                        <label class="form-label">Airline Code <span style="color:red"> *</span></label>
                        <input type="text" id="airlineCode" class="form-control" required>
                        <input type="hidden" id="airlineId">
                        <div class="invalid-feedback">Airline Code is required</div>
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Airline Name <span style="color:red"> *</span></label>
                        <input type="text" id="airlineName" class="form-control" required>
                        <div class="invalid-feedback">Airline Name is required</div>
                    </div>

                </div>

                <!-- SLABS -->
                <div class="card border-0 bg-light p-3">
                    <label class="fw-semibold mb-2">Slab Configuration</label>

                    <div class="row g-3">
                        <div class="col-md-2">
                            <input type="number" id="slab1" class="form-control" placeholder="Slab 1" required><span style="color:red"> *</span>
                            <div class="invalid-feedback">Slab 1 is required</div>
                        </div>
                        <div class="col-md-2"><input type="number" id="slab2" class="form-control" placeholder="Slab 2"></div>
                        <div class="col-md-2"><input type="number" id="slab3" class="form-control" placeholder="Slab 3"></div>
                        <div class="col-md-2"><input type="number" id="slab4" class="form-control" placeholder="Slab 4"></div>
                        <div class="col-md-2"><input type="number" id="slab5" class="form-control" placeholder="Slab 5"></div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-light border" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="btnSave">
                    <i class="bi bi-check-lg"></i> Save
                </button>
            </div>

        </div>
    </div>
</div>

<script src="~/js/airlinemaster.js" asp-append-version="true"></script>
