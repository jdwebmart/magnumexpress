
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    body {
        background: #f4f6f9;
    }

    .card {
        border-radius: 12px;
    }

    .modal-content {
        border-radius: 14px;
    }

    .table-hover tbody tr:hover {
        background: #eef3ff;
    }

    .btn {
        border-radius: 8px;
    }
</style>
<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold">Transport Master</h4>
            <small class="text-muted">Manage transport routes & timing</small>
        </div>
        <button class="btn btn-primary" id="btnAdd">
            <i class="bi bi-plus-lg"></i> Add Transport
        </button>
    </div>

    <!-- SEARCH -->
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex gap-2">
            <input type="text" id="search" class="form-control w-25"
                   placeholder="Search by destination...">
            <button class="btn btn-outline-primary" id="btnSearch">Search</button>
            <button class="btn btn-outline-secondary" onclick="loadData()">Reset</button>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body table-responsive">

            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Transport No</th>
                        <th>Origin Office</th>
                        <th>Destination Office</th>
                        <th>Mode Type</th>
                        <th>Airline</th>
                        <th>Mode Name</th>
                        <th>Departure Time</th>
                        <th>Arrival Time</th>
                        <th>Exp. Transit Day</th>
                        <th>Reaching Time</th>
                        <th>Service Type</th>
                        <th>Active</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody id="tblData"></tbody>
            </table>

        </div>
    </div>

</div>
<div class="modal fade" id="transportModal">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">

            <div class="modal-header bg-primary text-white">
                <h5 id="modalTitle">Add Transport</h5>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="tmid">
                <input type="hidden" id="modifiedBy" value="Admin">

                <div class="row g-3">

                    <!-- LEFT -->
                    <div class="col-md-6">
                        <label>Origin Office *</label>
                        <input type="text" id="originOffice" class="form-control">

                        <label class="mt-2">Mode Type <span style="color:red"> *</span></label>
                        <select id="modeType" class="form-select">
                            <option value="AIR">AIR</option>
                            <option value="SURFACE">SURFACE</option>
                            <option value="TRAIN">TRAIN</option>
                        </select>

                        <label class="mt-2">Mode Name <span style="color:red"> *</span></label>
                        <input type="text" id="modeName" class="form-control">

                        <label class="mt-2">Departure Time <span style="color:red"> *</span></label>
                        <input type="time" id="departureTime" class="form-control">

                        <label class="mt-2">Transit Day <span style="color:red"> *</span></label>
                        <input type="number" id="transitDay" class="form-control">
                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">
                        <label>Destination Office <span style="color:red"> *</span></label>
                        <input type="text" id="destinationOffice" class="form-control">

                        <label class="mt-2">Airline Name</label>
                        <input type="text" id="airlineName" class="form-control">

                        <label class="mt-2">Service Type <span style="color:red"> *</span></label>
                        <select id="serviceType" class="form-select">
                            <option value="ECONOMY">ECONOMY</option>
                            <option value="PREMIUM">PREMIUM</option>
                        </select>

                        <label class="mt-2">Arrival Time <span style="color:red"> *</span></label>
                        <input type="time" id="arrivalTime" class="form-control">

                        <label class="mt-2">
                            Exp. Reaching Time at Hub
                        </label>
                        <input type="time" id="reachingTime" class="form-control">

                        <div class="form-check mt-3">
                            <input type="checkbox" id="active" class="form-check-input">
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="btnSave">Save</button>
            </div>

        </div>
    </div>
</div>



<script src="~/js/transportmaster.js" asp-append-version="true"></script>