@{
    ViewData["Title"] = "Office Type Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#officeTypeModal">
    Add Office Type
</button>
<!-- MODAL -->
<div class="modal fade" id="officeTypeModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">OFFICE TYPE MASTER</h5>
                <small>FIELDS WITH <span class="text-danger">*</span> ARE MANDATORY</small>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <input type="hidden" id="Id" />

                <div class="row mb-3">
                    <div class="col-md-3">
                        <label>Type Code <span class="text-danger">*</span></label>
                        <input type="text" id="officeTypeCode" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Type Name <span class="text-danger">*</span></label>
                        <input type="text" id="officeTypeName" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label>Menu File Path</label>
                        <input type="text" id="MenuFilePath" class="form-control border-danger" />
                    </div>
                </div>

                <!-- CHECKBOXES -->
                <div class="row mb-3">
                    <div class="col-md-2">
                        <input type="checkbox" id="BookingManifestRequired" /> Booking Manifest
                    </div>
                    <div class="col-md-2">
                        <input type="checkbox" id="PrepaidBilling" /> Prepaid Billing
                    </div>
                    <div class="col-md-2">
                        <input type="checkbox" id="SkipStockValidation" /> Skip Stock
                    </div>
                    <div class="col-md-2">
                        <input type="checkbox" id="DeliveryChargeRequired" /> Delivery Charge
                    </div>
                    <div class="col-md-2">
                        <input type="checkbox" id="HeadOffice" /> Head Office
                    </div>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button class="btn btn-primary" onclick="save()">Save</button>
                <button class="btn btn-secondary" onclick="clearForm()">Clear</button>
                <button class="btn btn-danger" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>
<div class="container mt-4">

    
    <!-- SEARCH -->
    <div class="mt-3 d-flex">
        <input type="text" id="searchText" class="form-control w-25" placeholder="Search by Type Name" />
        <button class="btn btn-success ms-2" onclick="loadData()">GO</button>
    </div>

    <!-- TABLE -->
    <div class="mt-3">
        <table class="table table-bordered table-striped">
            <thead class="table-info">
                <tr>
                    <th>#</th>
                    <th>Type Code</th>
                    <th>Type Name</th>
                    <th>Head Office</th>
                    <th>Booking Req</th>
                    <th>Delivery Req</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tblBody"></tbody>
        </table>
    </div>

</div>

    <script src="~/js/officeTypeMaster.js"></script>
