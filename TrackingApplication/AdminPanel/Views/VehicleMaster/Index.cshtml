
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h4 class="fw-bold">🚗 Vehicle Master</h4>
        <button class="btn btn-primary" id="btnAdd">+ Add Vehicle</button>
    </div>

    <!-- SEARCH -->
    <div class="card p-3 mb-3 shadow-sm">
        <div class="d-flex gap-2">
            <input type="text" id="search" class="form-control" placeholder="Search by Vehicle No...">
            <button class="btn btn-outline-primary" id="btnSearch">Search</button>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Vehicle No</th>
                        <th>Type</th>
                        <th>Running</th>
                        <th>Model</th>
                        <th>Capacity</th>
                        <th>Vendor</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="tblData"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="vehicleModal">
<div class="modal-dialog modal-lg">
<div class="modal-content">

<div class="modal-header bg-primary text-white">
    <h5 id="modalTitle">Add Vehicle</h5>
    <button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

<input type="hidden" id="vehicleId">

<div class="row g-3">

    <div class="col-md-4">
                        <label>Vehicle Type <span style="color:red"> *</span></label>
        <select id="vehicleType" class="form-select">
            <option value="">Select</option>
            <option>OWN</option>
            <option>VENDOR</option>
        </select>
    </div>

    <div class="col-md-4">
                        <label>Running Type <span style="color:red"> *</span></label>
        <select id="runningType" class="form-select">
            <option>LOCAL</option>
            <option>OUTSTATION</option>
        </select>
    </div>

    <div class="col-md-4">
                        <label>Vehicle No <span style="color:red"> *</span></label>
        <input id="vehicleNo" class="form-control">
    </div>

    <div class="col-md-4">
        <label>Make & Model</label>
        <input id="model" class="form-control">
    </div>

    <div class="col-md-4">
                        <label>Capacity (Kg) <span style="color:red"> *</span></label>
        <input id="capacity" type="number" class="form-control">
    </div>

    <div class="col-md-4">
                        <label>Reporting Time <span style="color:red"> *</span></label>
        <input id="reportingTime" type="time" class="form-control">
    </div>

    <div class="col-md-6">
                        <label>Origin Office <span style="color:red"> *</span></label>
        <input id="originOffice" class="form-control">
    </div>

    <div class="col-md-6">
                        <label>Destination Office <span style="color:red"> *</span></label>
        <input id="destinationOffice" class="form-control">
    </div>

    <div class="col-md-6">
                        <label>Vendor Name <span style="color:red"> *</span></label>
        <input id="vendorName" class="form-control">
    </div>

    <div class="col-md-6">
        <label>Tracking Device ID</label>
        <input id="deviceId" class="form-control">
    </div>

    <div class="col-md-3">
        <label>Active</label><br>
        <input type="checkbox" id="active" checked>
    </div>

</div>

</div>

<div class="modal-footer">
    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button class="btn btn-success" id="btnSave">Save</button>
</div>

</div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<script src="~/js/VehicleMaster.js" asp-append-version="true"></script>