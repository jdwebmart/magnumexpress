
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h4 class="fw-bold">🏢 Vendor Master</h4>
        <button class="btn btn-primary" id="btnAdd">+ Add Vendor</button>
    </div>

    <!-- SEARCH -->
    <div class="card p-3 mb-3 shadow-sm">
        <div class="d-flex gap-2">
            <input type="text" id="search" class="form-control" placeholder="Search Vendor...">
            <button class="btn btn-outline-primary" id="btnSearch">Search</button>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Office</th>
                        <th>Vendor</th>
                        <th>Type</th>
                        <th>Contact</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="tblData"></tbody>
            </table>
        </div>
    </div>
</div>


<div class="modal fade" id="vendorModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 id="modalTitle">Add Vendor</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="vendorId">

                <!-- OFFICE -->
                <h6 class="fw-bold">Office Details</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label>Office Name *</label>
                        <input id="officeName" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label>Vendor Type *</label>
                        <select id="vendorType" class="form-select">
                            <option value="">Select</option>
                            <option>AIR</option>
                            <option>RAIL</option>
                            <option>SURFACE</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label>Vendor Code *</label>
                        <input id="vendorCode" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label>Vendor Name *</label>
                        <input id="vendorName" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label>GSTIN</label>
                        <input id="gstin" class="form-control">
                    </div>
                    <div class="col-md-3">
                        <label>Active</label><br>
                        <input type="checkbox" id="active" checked>
                    </div>
                </div>

                <!-- CONTACT -->
                <h6 class="fw-bold">Contact Person</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-4"><input id="contactName" class="form-control" placeholder="Name"></div>
                    <div class="col-md-4"><input id="mobile" class="form-control" placeholder="Mobile"></div>
                    <div class="col-md-4"><input id="phone" class="form-control" placeholder="Phone"></div>
                    <div class="col-md-6"><input id="email" class="form-control" placeholder="Email"></div>
                </div>

                <!-- ADDRESS -->
                <h6 class="fw-bold">Address</h6>
                <div class="row g-2">
                    <div class="col-md-6"><input id="address" class="form-control" placeholder="Address"></div>
                    <div class="col-md-2"><input id="pincode" class="form-control" placeholder="Pincode"></div>
                    <div class="col-md-2"><input id="city" class="form-control" placeholder="City"></div>
                    <div class="col-md-2"><input id="state" class="form-control" placeholder="State"></div>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="btnSave">Save</button>
            </div>

        </div>
    </div>
</div>


<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<script src="~/js/VendorMaster.js" asp-append-version="true"></script>