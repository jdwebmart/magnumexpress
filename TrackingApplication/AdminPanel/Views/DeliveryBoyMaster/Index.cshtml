
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- 1. jQuery FIRST -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- 2. Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- 3. SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h4 class="fw-bold">🚚 Delivery Boy Master</h4>
        <button class="btn btn-primary" id="btnAdd">+ Add Delivery Boy</button>
    </div>

    <div class="card p-3 mb-3 shadow-sm">
        <div class="d-flex gap-2">
            <input type="text" id="search" class="form-control" placeholder="Search...">
            <button class="btn btn-outline-primary" id="btnSearch">Search</button>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Office Name</th>
                        <th>Boy Code</th>
                        <th>Boy Name</th>
                        <th>Mobile No</th>
                        <th>Employee Name</th>
                        <th>Active</th>
                        <th>Allow Mobile Application</th>
                        <th>SIM No.</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="tblData"></tbody>
            </table>
        </div>
    </div>
</div>
<div class="modal fade" id="deliveryModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow">

            <!-- HEADER -->
            <div class="modal-header bg-primary text-white">
                <h5 id="modalTitle">Add Delivery Boy</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <input type="hidden" id="id">

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Office Name<span style="color:red"> *</span></label>
                        <input id="name" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Boy Code<span style="color:red"> *</span></label>
                        <input id="code" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Boy Name<span style="color:red"> *</span></label>
                        <input id="boyName" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Mobile No</label>
                        <input id="mobile" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Employee Name</label>
                        <input id="empName" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Status</label><br>
                        <input type="checkbox" id="active" checked> Active
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Allow Mobile Application</label><br>

                        <input type="checkbox" id="appAccess"> <br />
                        SIM No

                        <input id="simno" class="form-control mt-2" placeholder="Enter SIM No" disabled>
                    </div>

                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="btnSave">💾 Save</button>
            </div>

        </div>
    </div>
</div>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/DeliveryBoyMaster.js" asp-append-version="true"></script>