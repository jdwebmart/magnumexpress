
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    body {
        background: #f4f6f9;
    }

    .card {
        border-radius: 12px;
    }

    .table thead {
        background: #0d6efd;
        color: white;
    }

    .modal-header {
        background: #0d6efd;
        color: white;
    }
</style>
<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Office Request Master</h4>
        <button class="btn btn-primary" id="btnAdd">
            + Add Office Request
        </button>
    </div>

    <!-- Table -->
    <div style="overflow-x:scroll">
    <table class="table table-bordered table-hover text-center">
        <thead>
            <tr>
                <th>ID</th>
                <th>Office Name</th>
                <th>Reference By</th>
                <th>Reference Name</th>
                    <th>Plan Adopted</th>
                <th>Amount Paid</th>
                <th>Deposit</th>
                <th>Name</th>
                <th>Address</th>
                <th>Mobile</th>
                <th>Phone</th>
                <th>Pincode</th>
                <th>City</th>
                <th>State</th>
                <th>Personal No</th>
                <th>Email</th>
                <th>PAN</th>
                <th>Service Tax</th>
                <th>Document1</th>
                <th>Document2</th>
                <th>Document3</th>
                <th>Document4</th>
                <th>Document5</th>
                <th>Document6</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="tblData"></tbody>
    </table>
    </div>
<!-- MODAL -->
<div class="modal fade" id="officeModal">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle">Office Request</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="Id">

                <!-- Office Details -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">Office Details</div>
                    <div class="card-body row g-3">

                        <div class="col-md-3">
                                <label>Reference By <span style="color:red"> *</span></label>
                                
                            <select id="ReferenceBy" class="form-select" required>
                                    <option value="-1" selected="selected">--Select--</option>
                                <option>AGENT</option>
                                <option>EMPLOYEE</option>
                            </select>
                                <span id="ReferenceByError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                                <label>Reference Name <span style="color:red"> *</span></label>
                               
                                <input type="text" id="ReferenceName" required class="form-control">
                                <span id="ReferenceNameError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                                <label>Office Name <span style="color:red"> *</span></label>
                                <input type="text" id="OfficeName" required class="form-control">
                                <span id="OfficeNameError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                                <label>Plan Adopted <span style="color:red"> *</span></label>
                                
                                <select id="Plan" class="form-select" required>
                                    <option value="-1" selected>--Select--</option>
                                    <option>SILVER</option>
                                    <option>GOLD</option>
                            </select>
                                <span id="PlanError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label>Amount Paid</label><br>
                            <input type="checkbox" id="AmountPaid">
                        </div>

                        <div class="col-md-3">
                            <label>Deposit Amount</label>
                                <input type="text" id="DepositAmount" inputmode="numeric" maxlength="15" class="form-control">
                        </div>

                    </div>
                </div>

                <!-- Contact Person -->
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">Contact Person</div>
                    <div class="card-body row g-3">

                        <div class="col-md-4">
                                <label>Name <span style="color:red"> *</span></label>
                               
                                <input type="text" id="ContactName" required class="form-control">
                                <span id="ContactNameError" class="text-danger"></span>
                        </div>

                        <div class="col-md-2">
                                <label>Mobile <span style="color:red"> *</span></label>
                               
                                <input type="text" id="Mobile" inputmode="numeric" maxlength="10" required class="form-control">
                                <span id="MobileError" class="text-danger"></span>
                        </div>

                        <div class="col-md-2">
                            <label>Phone</label>
                            <input type="text" id="Phone" class="form-control">
                        </div>

                        <div class="col-md-2">
                            <label>Personal No</label>
                            <input type="text" id="PersonalNo" class="form-control">
                        </div>

                        <div class="col-md-2">
                            <label>Email</label>
                            <input type="email" id="Email" class="form-control">
                                <span id="EmailError" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <!-- Address -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">Address</div>
                    <div class="card-body row g-3">

                        <div class="col-md-12">
                                <label>Address <span style="color:red"> *</span></label>
                                
                                <textarea id="Address" required class="form-control"></textarea>
                                <span id="AddressError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                                <label>Pincode <span style="color:red"> *</span></label>
                               
                                <input type="text" id="Pincode" required class="form-control">
                                <span id="PincodeError" inputmode="numeric" maxlength="6" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label>City</label>
                                <input type="text" id="City" required class="form-control">
                                <span id="CityError" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label>State</label>
                               
                                <input type="text" id="State" required class="form-control">
                                <span id="StateError" class="text-danger"></span>
                        </div>

                    </div>
                </div>

                <!-- Other Details -->
                <div class="card mb-3">
                    <div class="card-header bg-dark text-white">Other Details</div>
                    <div class="card-body row g-3">

                        <div class="col-md-6">
                            <label>PAN Number</label>
                            <input type="text" id="PAN" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label>Service Tax Number</label>
                            <input type="text" id="ServiceTax" class="form-control">
                        </div>

                    </div>
                </div>

                <!-- Upload Documents -->
                <div class="card">
                    <div class="card-header bg-warning">Upload Documents</div>
                    <div class="card-body row g-3">

                        <div class="col-md-4">
                                <label>Document 1 <span style="color:red"> *</span></label>
                            <input type="file" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Document 2</label>
                            <input type="file" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Document 3</label>
                            <input type="file" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Document 4</label>
                            <input type="file" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Document 5</label>
                            <input type="file" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label>Document 6</label>
                            <input type="file" class="form-control">
                        </div>
                            <div class="col-md-4">
                                <label>Status</label>
                                <select id="Status" class="form-select">
                                    <option value="-1" selected>--Select--</option>
                                    <option value="1">IsActive</option>
                                    <option value="0">Pending</option>
                                </select>
                                <input type="hidden" id="createdBy" name="createdBy" value="Admin">
                            </div>
                           
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-success" id="btnSave">Save</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>
</div>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<script src="~/js/officeRequest.js" asp-append-version="true"></script>